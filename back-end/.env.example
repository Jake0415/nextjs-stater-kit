# 서버
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# PostgreSQL (Docker: mh-ocr-postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mh_ocr_ai

# MongoDB (Docker: mh-ocr-mongo)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=mh_ocr_ai

# MinIO (Docker: mh-ocr-minio)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# SSO (MHSSO와 동일한 시크릿)
SSO_JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars-long
SSO_JWT_ISSUER=mhsso-ai
